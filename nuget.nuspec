<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <version>5.0.0-beta.1</version>
        <id>datatables.net-fixedheader-se</id>
        <description>This is FixedHeader for DataTables with styling for [SemanticUI](https://semantic-ui.com/)</description>
        <repository type="git" url="https://github.com/DataTables/FixedHeader"/>
        <authors>SpryMedia Ltd</authors>
        <projectUrl>http://datatables.net</projectUrl>
        <license type="expression">MIT</license>
        <tags>FixedHeader  Fixed Headers  Sticky  Semantic  SemanticUI  Semantic UI  Datatables table</tags>
        <dependencies>
            <dependency id="datatables.net-fixedheader" version="5.0.0-beta.1"/>
            <dependency id="datatables.net-se" version="3.0.0-0"/>
        </dependencies>
        <contentFiles>
            <files include="**/*" buildAction="Content"/>
        </contentFiles>
        <readme>Readme.md</readme>
    </metadata>
    <files>
        <file src="Readme.md" target=""/>
        <file src="js/fixedHeader.semanticui.js" target="content\Scripts"/>
        <file src="js/fixedHeader.semanticui.js" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/fixedHeader.semanticui.min.js" target="content\Scripts"/>
        <file src="js/fixedHeader.semanticui.min.js" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/fixedHeader.semanticui.min.mjs" target="content\Scripts"/>
        <file src="js/fixedHeader.semanticui.min.mjs" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/fixedHeader.semanticui.mjs" target="content\Scripts"/>
        <file src="js/fixedHeader.semanticui.mjs" target="contentFiles\any\any\wwwroot\js"/>
        <file src="css/fixedHeader.semanticui.css" target="content\Content"/>
        <file src="css/fixedHeader.semanticui.css" target="contentFiles\any\any\wwwroot\css"/>
        <file src="css/fixedHeader.semanticui.min.css" target="content\Content"/>
        <file src="css/fixedHeader.semanticui.min.css" target="contentFiles\any\any\wwwroot\css"/>
    </files>
</package>
